# Octavus Configuration
# Get your API keys from https://octavus.ai

# Platform URL (optional - defaults to https://octavus.ai)
OCTAVUS_API_URL=https://octavus.ai

# API Key for runtime operations
OCTAVUS_API_KEY=your-api-key

# CLI API Key for agent syncing (optional - can use OCTAVUS_API_KEY)
OCTAVUS_CLI_API_KEY=your-cli-api-key

# Agent ID (set after running: npm run agents:sync)
OCTAVUS_AGENT_ID=your-agent-id
